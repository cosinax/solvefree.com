# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# CDK build output
infra/cdk.out/
infra/node_modules/
infra/*.js
infra/*.d.ts

# Playwright MCP logs
.playwright-mcp/

# Agent queue files
agent/

# Secrets & credentials
*.key
*.secret
*.p12
*.pfx
credentials.json
secrets.json
aws-exports.js
.aws/

# OS
Thumbs.db
agent/queue.lock
